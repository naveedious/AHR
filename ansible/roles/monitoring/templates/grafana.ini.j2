[paths]
data = /var/lib/grafana
logs = /var/log/grafana
plugins = /var/lib/grafana/plugins
provisioning = /etc/grafana/provisioning

[server]
protocol = http
http_port = 3000

[database]
type = sqlite3
path = grafana.db

[security]
admin_user = admin

[users]
allow_sign_up = false

[auth.anonymous]
enabled = false
